{
  "name": "@clicka/booking",
  "version": "0.1.0",
  "description": "White-label booking widget for salon sites powered by the Clicka engine API.",
  "type": "module",
  "sideEffects": [
    "./dist/booking.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/booking.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build:js": "tsup",
    "build:css": "tailwindcss -c ./tailwind.config.cjs -i ./src/styles.css -o ./dist/booking.css --minify",
    "build": "npm run clean && npm run build:js && npm run build:css"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "lucide-react": "^0.4 || ^0.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
